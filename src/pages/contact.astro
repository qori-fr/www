---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '../config';

const lang = 'es';
const pages = await getCollection('pages');
const page = pages.find((p) => p.data.path === 'contact' && p.data.lang === lang);
if (!page) throw new Error('Contact page not found');
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} lang={lang} isHome={false} pageTitle={page.data.title}>
  <section class="section">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <div class="content">
            <Content />
            <p>
              <strong>Email&nbsp;:</strong>&nbsp;<span set:html={siteConfig.email}/><br />
              <strong>Teléfono&nbsp;:</strong>&nbsp;<span set:html={siteConfig.phone}/>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
